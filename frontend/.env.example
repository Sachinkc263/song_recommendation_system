# Copy this file to .env and fill in values
# During development, Vite proxies /api to the backend automatically —
# leave VITE_API_URL empty for local dev.
#
# For a deployed frontend (Vercel), set it to the backend origin, e.g.:
#   VITE_API_URL=https://song-recommendation-system-4uib.onrender.com

VITE_API_URL=
