# ══════════════════════════════════════════════════════════════
# Backend environment variables — copy to .env and fill in
# All values are optional; sensible defaults live in config/settings.py
# ══════════════════════════════════════════════════════════════

# Hugging Face dataset holding the runtime data files
# (recommender_payload.pkl, data_clean.csv, data_with_cover.csv, data_w_genres.csv)
HF_DATASET_REPO=Sachin263/spotify-rec-data

# Hugging Face token — higher rate limits for scripts/download_data.py
# Create one at https://huggingface.co/settings/tokens (Read role is enough)
HF_TOKEN=

# Extra CORS origins for the API, comma-separated.
# Local dev origins (localhost:5173 etc.) are always allowed.
# In production (Render) this is set to the Vercel frontend URL:
ALLOWED_ORIGINS=https://song-recommendation-system-psi.vercel.app

# Logging level for the backend (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Base URL used by the integration tests (tests/test_api.py)
# Point at production to smoke-test the deployed backend:
#   API_BASE_URL=https://song-recommendation-system-4uib.onrender.com
API_BASE_URL=http://localhost:8000
