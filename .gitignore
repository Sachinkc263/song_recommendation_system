# ══════════════════════════════════════════════════════════════
# Spotify Music Recommendation System — .gitignore
# ══════════════════════════════════════════════════════════════

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
build/
.eggs/
*.pyo
*.pyd

# ── Virtual environments ──────────────────────────────────────
.venv/
venv/
env/
ENV/
.Python

# ── Environment / secrets ────────────────────────────────────
.env
*.env
!.env.example
!frontend/.env.example
secrets.json
credentials.json

# ── Jupyter ──────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── Raw data (large Kaggle CSVs — download separately) ───────
data/raw/*.csv
data/raw/*.json
data/raw/*.zip
!data/raw/.gitkeep

# ── Processed data (generated by notebooks — not committed) ──
data/processed/*.csv
data/processed/*.pkl
data/processed/*.parquet
!data/processed/.gitkeep
# Exception: tiny config file with feature column names
!data/processed/feature_columns.json

# ── External data ────────────────────────────────────────────
data/external/
!data/external/.gitkeep

# ── Trained models (large binary files) ──────────────────────
models/*.pkl
models/*.joblib
models/*.h5
models/*.pt
models/*.pth
!models/.gitkeep

# ── Reports / figures ────────────────────────────────────────
# Figures are committed — they showcase EDA and evaluation results
# (remove the lines below if you prefer not to track them)

# ── Frontend — Node.js ───────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.env
frontend/.env.local
frontend/.env.production
frontend/coverage/
frontend/.cache/

# ── IDE ──────────────────────────────────────────────────────
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# ── OS ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo

# ── Logs ─────────────────────────────────────────────────────
*.log
logs/

# ── Docker ───────────────────────────────────────────────────
# (compose override files are usually local-only)
docker-compose.override.yml
