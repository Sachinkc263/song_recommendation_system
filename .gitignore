# ── Python ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ─────────────────────────────────────
.env
.venv
env/
venv/
ENV/

# ── Jupyter ──────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── Data ─────────────────────────────────────────────────────
# Raw data is tracked by Git LFS or stored externally — do not commit large CSVs
data/raw/*.csv
data/processed/*.csv
data/processed/*.pkl
data/processed/*.json
data/external/

# Keep directory structure
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/external/.gitkeep

# ── Models ───────────────────────────────────────────────────
models/*.pkl
models/*.joblib
models/*.h5
!models/.gitkeep

# ── Reports / figures ────────────────────────────────────────
reports/figures/*.png
reports/figures/*.pdf
reports/figures/*.svg
!reports/figures/.gitkeep

# ── IDE ──────────────────────────────────────────────────────
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# ── OS ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Secrets ──────────────────────────────────────────────────
.env
*.env
secrets.json
credentials.json
